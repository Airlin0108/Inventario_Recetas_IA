# =====================================================
# VARIABLES DE ENTORNO - Copiar a .env y completar
# NUNCA subir el archivo .env al repositorio
# =====================================================

# --- Base de datos PostgreSQL ---
# Host del servidor PostgreSQL (usar "db" si se usa Docker Compose)
DATABASE_HOST=db
# Puerto de PostgreSQL (default: 5432)
DATABASE_PORT=5432
# Nombre de la base de datos
DATABASE_NAME=inventario_recetas
# Usuario de la base de datos
DATABASE_USER=postgres
# Contrasena de la base de datos (OBLIGATORIO en produccion: usar una fuerte y unica)
# Generar con: openssl rand -base64 24
DATABASE_PASSWORD=tu_contrasena_segura_aqui
# URL completa de conexion. Debe coincidir con DATABASE_USER/PASSWORD/NAME de arriba.
# En produccion el docker-compose la construye solo; definela aqui para ejecucion local.
DATABASE_URL=postgresql://postgres:tu_contrasena_segura_aqui@db:5432/inventario_recetas

# --- Autenticacion JWT ---
# Clave secreta para firmar los tokens JWT (OBLIGATORIO: minimo 32 caracteres aleatorios)
# Generar con: openssl rand -hex 32
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria
# Algoritmo de firma JWT
ALGORITHM=HS256
# Tiempo de expiracion del token en minutos (default: 60 minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- OpenRouter API (LLM) ---
# Clave de API de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo de LLM a utilizar (ejemplos: deepseek/deepseek-chat, mistralai/mistral-7b-instruct)
LLM_MODEL=deepseek/deepseek-chat
# URL base de la API de OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Configuracion de la aplicacion ---
# Nombre de la aplicacion (aparece en la documentacion Swagger)
APP_NAME=Inventario Recetas IA
# Entorno de ejecucion: development | production
ENVIRONMENT=development
# Puerto en que corre la aplicacion (solo desarrollo)
APP_PORT=8000

# --- Seguridad / CORS ---
# Origenes permitidos para llamadas cruzadas, separados por comas.
# Dejar vacio si la interfaz se sirve desde el mismo dominio que la API (caso normal).
# Ejemplo si tienes un frontend aparte: CORS_ORIGINS=https://app.midominio.com
CORS_ORIGINS=

# --- Despliegue en produccion (Caddy / SSL automatico) ---
# Dominio propio que apunta al servidor (registro DNS tipo A -> IP del VPS).
# Caddy obtendra el certificado SSL de Let's Encrypt automaticamente para este dominio.
DOMAIN=recetas.midominio.com
